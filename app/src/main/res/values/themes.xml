<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme with Material Design 3 -->
    <style name="Theme.VariableFontTest" parent="@style/Theme.Material3.DayNight.NoActionBar">
        <!-- Enable edge-to-edge display -->
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="27">shortEdges</item>
        
        <!-- Use Material Theme Overlay for dynamic colors on Android 12+ -->
        <item name="materialThemeOverlay">@style/ThemeOverlay.App.DynamicColors</item>
        
        <!-- Force MD3 styles for Preference components -->
        <item name="preferenceTheme">@style/PreferenceThemeOverlay.v14.Material</item>
        <!-- Force MD3 style for SeekBar -->
        <item name="seekBarStyle">@style/Widget.AppCompat.SeekBar.Material</item>
    </style>
    
    <!-- Dynamic colors overlay - only applies on Android 12+ (API 31+) -->
    <!-- On older versions, falls back to default Material 3 colors -->
    <style name="ThemeOverlay.App.DynamicColors" parent="">
        <!-- These attributes will be overridden by system dynamic colors on Android 12+ -->
        <!-- No hardcoded colors here to allow dynamic color picking -->
    </style>
</resources>
