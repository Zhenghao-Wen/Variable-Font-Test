<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme with Material Design 3 -->
    <style name="Theme.VariableFontTest" parent="@style/Theme.Material3.DayNight.NoActionBar">
        <!-- Enable edge-to-edge display -->
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="27">shortEdges</item>

        <!-- Enable dynamic colors for Android 12+ (Material You) using ThemeOverlay -->
        <item name="android:theme">@style/ThemeOverlay.Material3.DynamicColors.DayNight</item>

        <!-- Force MD3 styles for Preference components -->
        <item name="preferenceTheme">@style/PreferenceThemeOverlay.Material3</item>
    </style>

    <!-- MD3 Preference theme with proper switch style -->
    <style name="PreferenceThemeOverlay.Material3" parent="@style/PreferenceThemeOverlay">
        <item name="switchPreferenceCompatStyle">@style/Preference.SwitchPreferenceCompat.Material3</item>
        <item name="switchPreferenceStyle">@style/Preference.SwitchPreference.Material3</item>
        <item name="editTextPreferenceStyle">@style/Preference.EditTextPreference.Material3</item>
    </style>

    <style name="Preference.SwitchPreferenceCompat.Material3" parent="@style/Preference.SwitchPreferenceCompat.Material">
        <item name="android:widgetLayout">@layout/preference_widget_switch_compat</item>
    </style>

    <style name="Preference.SwitchPreference.Material3" parent="@style/Preference.SwitchPreference.Material">
        <item name="android:widgetLayout">@layout/preference_widget_switch</item>
    </style>

    <style name="Preference.EditTextPreference.Material3" parent="@style/Preference.EditTextPreference.Material">
        <item name="android:dialogTheme">@style/DialogTheme.Material3</item>
    </style>

    <!-- MD3 Dialog Theme for EditTextPreference -->
    <style name="DialogTheme.Material3" parent="@style/ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorPrimary">@android:color/system_accent1_500</item>
        <item name="colorOnPrimary">@android:color/system_accent1_100</item>
        <item name="colorSurface">@android:color/system_neutral1_100</item>
        <item name="colorOnSurface">@android:color/system_neutral1_900</item>
    </style>
</resources>
