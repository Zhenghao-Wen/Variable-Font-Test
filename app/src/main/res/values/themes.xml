<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme with Material Design 3 -->
    <style name="Theme.VariableFontTest" parent="@style/Theme.Material3.DayNight.NoActionBar">
        <!-- Enable edge-to-edge display -->
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="27">shortEdges</item>

        <!-- Apply MD3 preference theme with dialog styling -->
        <item name="preferenceTheme">@style/PreferenceThemeOverlay.v14.Material</item>
        <!-- MD3 dialog styling: BOTH prefixed and non-prefixed for full coverage -->
        <item name="android:dialogTheme">@style/ThemeOverlay.Material3.MaterialAlertDialog</item>
        <item name="android:alertDialogTheme">@style/ThemeOverlay.Material3.MaterialAlertDialog</item>
        <item name="alertDialogTheme">@style/ThemeOverlay.Material3.MaterialAlertDialog</item>
        <item name="dialogTheme">@style/ThemeOverlay.Material3.MaterialAlertDialog</item>

        <!-- ══ 修复旧版 SeekBar 饱和度 ══ 强制 SeekBar 的 progressTint/thumbTint 解析到 ?attr/colorPrimary
             （暗色动态取色 = system_accent1_200），而非被 PreferenceThemeOverlay 降级到 colorPrimaryContainer（system_accent1_100） -->
        <item name="android:seekBarStyle">@style/Widget.App.SeekBar.MD3Tint</item>
    </style>

    <!-- 旧版 SeekBar 的 MD3 色彩修正 -->
    <style name="Widget.App.SeekBar.MD3Tint" parent="Widget.AppCompat.SeekBar">
        <item name="android:progressTint">?attr/colorPrimary</item>
        <item name="android:thumbTint">?attr/colorPrimary</item>
    </style>
</resources>
