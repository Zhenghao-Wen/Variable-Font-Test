<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme for night mode -->
    <style name="Theme.VariableFontTest" parent="@style/Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color for dark mode -->
        <item name="colorPrimary">@color/cyan_200</item>
        <!-- For transparent caption bar -->
        <item name="colorPrimaryDark">@android:color/transparent</item>
        <!-- https://m3.material.io/styles/color/dark-theme -->
        <item name="colorSurface">#1E1E1E</item>
        <item name="colorPrimaryVariant">@color/cyan_500</item>
        <!-- Secondary brand color for dark mode -->
        <item name="colorSecondary">@color/pink_A200</item>
        <item name="colorSecondaryVariant">@color/pink_500</item>

        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="27">shortEdges</item>
        
        <!-- Material Design 3 specific attributes for dark mode -->
        <item name="materialThemeOverlay">@style/ThemeOverlay.App.Material3.Dark</item>
    </style>
    
    <!-- Material Design 3 overlay for dynamic colors in dark mode -->
    <style name="ThemeOverlay.App.Material3.Dark" parent="">
        <!-- Dark mode MD3 color palette -->
        <item name="colorPrimaryContainer">@color/cyan_700</item>
        <item name="colorOnPrimaryContainer">@color/cyan_200</item>
        <item name="colorSecondaryContainer">@color/pink_500</item>
        <item name="colorOnSecondaryContainer">@color/pink_A200</item>
        <item name="colorSurfaceVariant">#49454F</item>
        <item name="colorOnSurfaceVariant">#CAC4D0</item>
        <!-- MD3 Switch thumb and track colors for dark mode -->
        <item name="colorSwitchThumbNormal">@color/cyan_200</item>
    </style>
</resources>
