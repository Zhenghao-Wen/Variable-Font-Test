<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Night mode theme - uses Material 3 defaults with dynamic colors -->
    <style name="Theme.VariableFontTest" parent="@style/Theme.Material3.DayNight.NoActionBar">
        <!-- Enable edge-to-edge display -->
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="27">shortEdges</item>
        
        <!-- Enable dynamic colors for Android 12+ (Material You) -->
        <item name="android:colorPrimary">@android:color/system_accent1_200</item>
        <item name="android:colorSecondary">@android:color/system_accent2_200</item>
        <item name="android:colorTertiary">@android:color/system_accent3_200</item>
        <item name="android:colorBackground">@android:color/system_neutral1_900</item>
        <item name="colorSurface">@android:color/system_neutral1_900</item>
        <item name="colorOnPrimary">@android:color/system_accent1_900</item>
        <item name="colorOnSecondary">@android:color/system_accent2_900</item>
        <item name="colorOnTertiary">@android:color/system_accent3_900</item>
        <item name="colorOnBackground">@android:color/system_neutral1_100</item>
        <item name="colorOnSurface">@android:color/system_neutral1_100</item>
    </style>
</resources>
