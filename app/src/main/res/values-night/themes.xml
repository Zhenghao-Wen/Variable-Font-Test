<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Night mode theme - uses Material 3 defaults with dynamic colors -->
    <style name="Theme.VariableFontTest" parent="@style/Theme.Material3.DayNight.NoActionBar">
        <!-- Enable edge-to-edge display -->
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="27">shortEdges</item>
        
        <!-- Use Material Theme Overlay for dynamic colors on Android 12+ -->
        <item name="materialThemeOverlay">@style/ThemeOverlay.App.DynamicColors</item>
    </style>
    
    <!-- Dynamic colors overlay for night mode - empty to use system defaults -->
    <style name="ThemeOverlay.App.DynamicColors" parent="">
        <!-- No hardcoded colors to allow dynamic color picking -->
    </style>
</resources>
