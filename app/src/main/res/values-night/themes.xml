<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Night mode theme - uses Material 3 defaults with dynamic colors -->
    <style name="Theme.VariableFontTest" parent="@style/Theme.Material3.DayNight.NoActionBar">
        <!-- Enable edge-to-edge display -->
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="27">shortEdges</item>

        <!-- Enable dynamic colors for Android 12+ (Material You) using ThemeOverlay -->
        <item name="android:theme">@style/ThemeOverlay.Material3.DynamicColors.DayNight</item>
    </style>
</resources>
